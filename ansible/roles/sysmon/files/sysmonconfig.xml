<Sysmon schemaversion="4.90">
  <HashAlgorithms>md5,sha256</HashAlgorithms>
  <CheckRevocation/>
  <EventFiltering>

    <!-- Event ID 1: Process Create — capture all, exclude noisy system processes -->
    <RuleGroup name="" groupRelation="or">
      <ProcessCreate onmatch="exclude">
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>
        <Image condition="is">C:\Windows\System32\WerFault.exe</Image>
        <Image condition="is">C:\Windows\System32\conhost.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!-- Event ID 3: Network Connection — capture outbound, exclude common noise -->
    <RuleGroup name="" groupRelation="or">
      <NetworkConnect onmatch="exclude">
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>
        <DestinationPort condition="is">443</DestinationPort>
        <DestinationPort condition="is">80</DestinationPort>
      </NetworkConnect>
    </RuleGroup>

    <!-- Event ID 7: Image Load (DLL) — disabled by default, too noisy without tuning -->
    <RuleGroup name="" groupRelation="or">
      <ImageLoad onmatch="include">
        <Signed condition="is">false</Signed>
      </ImageLoad>
    </RuleGroup>

    <!-- Event ID 8: CreateRemoteThread — capture all (used by Mimikatz, injectors) -->
    <RuleGroup name="" groupRelation="or">
      <CreateRemoteThread onmatch="exclude"/>
    </RuleGroup>

    <!-- Event ID 10: Process Access — key for LSASS dump detection -->
    <RuleGroup name="" groupRelation="or">
      <ProcessAccess onmatch="include">
        <TargetImage condition="is">C:\Windows\system32\lsass.exe</TargetImage>
      </ProcessAccess>
    </RuleGroup>

    <!-- Event ID 11: File Create — capture all for ransomware detection -->
    <RuleGroup name="" groupRelation="or">
      <FileCreate onmatch="exclude">
        <TargetFilename condition="contains">AppData\Local\Temp\</TargetFilename>
        <TargetFilename condition="end with">.log</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- Event ID 12/13: Registry Events — capture Run keys and common persistence -->
    <RuleGroup name="" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">SOFTWARE\Microsoft\Windows\CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- Event ID 15: FileCreateStreamHash — ADS detection -->
    <RuleGroup name="" groupRelation="or">
      <FileCreateStreamHash onmatch="exclude"/>
    </RuleGroup>

    <!-- Event ID 17/18: Named Pipe — capture Cobalt Strike default pipes -->
    <RuleGroup name="" groupRelation="or">
      <PipeEvent onmatch="include">
        <PipeName condition="contains">msagent_</PipeName>
        <PipeName condition="contains">postex_</PipeName>
        <PipeName condition="is">\MSSE-</PipeName>
      </PipeEvent>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
